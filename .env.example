# SearchMuse Environment Variables
# Copy this file to .env and adjust values as needed

# LLM Configuration (Ollama)
SEARCHMUSE_LLM_BASE_URL=http://localhost:11434
SEARCHMUSE_LLM_MODEL=mistral

# Search Configuration
SEARCHMUSE_MAX_ITERATIONS=5
SEARCHMUSE_MIN_SOURCES=3

# Scraping Configuration
SEARCHMUSE_REQUEST_DELAY=1.0
SEARCHMUSE_REQUEST_TIMEOUT=30

# Database
SEARCHMUSE_DB_PATH=~/.searchmuse/searchmuse.db

# Logging
SEARCHMUSE_LOG_LEVEL=INFO
